        <Item class="ModuleScript" referent="14">
          <Properties>
            <string name="Name">buffer</string>
            <string name="Source"><![CDATA[--[[
	******************************************************************************
	* @file		: .../src/utils/buffer.lua
	* @author	: Scrpt2r
	* @date		: April 16 2026
	* @lastEdit	: April 17 2026 18:28
	* @brief	: Buffer writer / reader for any type avaible on roblox.
	* @version	: 0.1.5
	******************************************************************************
	* @attention
	*
	* Copyright © 2026 Axon Corporation.
	* All rights reserved.
	*
	* This software is licensed under terms that can be found in the LICENSE file
	* in the root directory of this software component.
	* If no LICENSE file comes with this software, it is provided AS-IS.
	*
	******************************************************************************
--]]

--// Libs
local types = require(script.Parent.Parent:WaitForChild("global"):WaitForChild("types"))

--// Types
export type _writerType = types.writerType
type writerType = _writerType

export type _readerType = types.readerType
type readerType = _readerType

export type _encodeResult = types.encodeResult
type encodeResult = _encodeResult

--// Constants
local INITIAL_SIZE = 128
local T = {
	NIL = 0x00,
	BOOL = 0x01,
	F64 = 0x02,
	F32 = 0x03,
	I8 = 0x04,
	U8 = 0x05,
	I16 = 0x06,
	U16 = 0x07,
	I32 = 0x08,
	U32 = 0x09,
	STRING = 0x0A,
	VECTOR3 = 0x0B,
	VECTOR2 = 0x0C,
	CFRAME_FULL = 0x0D,
	CFRAME_AXIAL = 0x0E,
	COLOR3_F = 0x0F,
	COLOR3_RGB = 0x10,
	BRICKCOLOR = 0x11,
	UDIM = 0x12,
	UDIM2 = 0x13,
	RECT = 0x14,
	NUMRANGE = 0x15,
	NUMSEQ = 0x16,
	COLORSEQ = 0x17,
	INSTANCE = 0x18,
	ENUM = 0x19,
	TABLE = 0x1A,
	ARRAY = 0x1B,
	VECTOR4 = 0x1C,
	REGION3 = 0x1D,
	RAY = 0x1E,
}

--// Functions
function growBuffer(w: writerType, need: number)
	if w._cursor + need <= w._size then
		return
	end

	local newSize = w._size
	while newSize < w._cursor + need do
		newSize *= 2
	end

	local newBuf = buffer.create(newSize)
	buffer.copy(newBuf, 0, w._buf, 0, w._cursor)

	w._buf = newBuf
	w._size = newSize
end

--// Writer Decleration
local writer = {}
writer.__index = writer

--// Writer Functions
function writer.new(): writerType
	local self = setmetatable({
		_buf = buffer.create(INITIAL_SIZE),
		_cursor = 0,
		_size = INITIAL_SIZE,
		_instances = {},
	}, writer) :: any

	return self
end

function writer:writeU8(v: number)
	growBuffer(self, 1)

	buffer.writeu8(self._buf, self._cursor, v)
	self._cursor += 1
end

function writer:writeU16(v: number)
	growBuffer(self, 2)

	buffer.writeu16(self._buf, self._cursor, v)
	self._cursor += 2
end

function writer:writeU32(v: number)
	growBuffer(self, 4)

	buffer.writeu32(self._buf, self._cursor, v)
	self._cursor += 4
end

function writer:writeI8(v: number)
	growBuffer(self, 1)

	buffer.writei8(self._buf, self._cursor, v)
	self._cursor += 1
end

function writer:writeI16(v: number)
	growBuffer(self, 2)

	buffer.writei16(self._buf, self._cursor, v)
	self._cursor += 2
end

function writer:writeI32(v: number)
	growBuffer(self, 4)

	buffer.writei32(self._buf, self._cursor, v)
	self._cursor += 4
end

function writer:writeF32(v: number)
	growBuffer(self, 4)

	buffer.writef32(self._buf, self._cursor, v)
	self._cursor += 4
end

function writer:writeF64(v: number)
	growBuffer(self, 8)

	buffer.writef64(self._buf, self._cursor, v)
	self._cursor += 8
end

function writer:writeString(v: string)
	local len = #v
	self:writeU32(len)

	growBuffer(self, len)

	buffer.writestring(self._buf, self._cursor, v)
	self._cursor += len
end

function writer:writeBool(v: boolean)
	self:writeU8(v and 1 or 0)
end

function writer:writeVector3(v: Vector3)
	self:writeF32(v.X)
	self:writeF32(v.Y)
	self:writeF32(v.Z)
end

function writer:writeVector2(v: Vector2)
	self:writeF32(v.X)
	self:writeF32(v.Y)
end

function writer:writeCFrame(v: CFrame)
	local pos = v.Position
	self:writeF32(pos.X)
	self:writeF32(pos.Y)
	self:writeF32(pos.Z)

	local rx, ry, rz = v:ToEulerAnglesXYZ()
	self:writeF32(rx)
	self:writeF32(ry)
	self:writeF32(rz)
end

function writer:writeColor3(v: Color3, compact: boolean?)
	if compact then
		self:writeU8(math.round(v.R * 255))
		self:writeU8(math.round(v.G * 255))
		self:writeU8(math.round(v.B * 255))
	else
		self:writeF32(v.R)
		self:writeF32(v.G)
		self:writeF32(v.B)
	end
end

function writer:writeUDim(v: UDim)
	self:writeF32(v.Scale)
	self:writeI32(v.Offset)
end

function writer:writeUDim2(v: UDim2)
	self:writeF32(v.X.Scale)
	self:writeI32(v.X.Offset)
	self:writeF32(v.Y.Scale)
	self:writeI32(v.Y.Offset)
end

function writer:writeRect(v: Rect)
	self:writeF32(v.Min.X)
	self:writeF32(v.Min.Y)
	self:writeF32(v.Max.X)
	self:writeF32(v.Max.Y)
end

function writer:writeNumRange(v: NumberRange)
	self:writeF32(v.Min)
	self:writeF32(v.Max)
end

function writer:writeInstance(v: Instance)
	table.insert(self._instances, v)
	self:writeU16(#self._instances - 1)
end

function writer:writeEnum(v: EnumItem)
	self:writeString(tostring(v.EnumType) .. "." .. v.Name)
end

function writer:writeValue(v: any)
	local t = typeof(v)

	if v == nil then
		self:writeU8(T.NIL)
	elseif t == "boolean" then
		self:writeU8(T.BOOL)
		self:writeBool(v)
	elseif t == "number" then
		if v == math.floor(v) and v >= -2147483648 and v <= 2147483647 then
			if v >= -128 and v <= 127 then
				self:writeU8(T.I8)
				self:writeI8(v)
			elseif v >= -32768 and v <= 32767 then
				self:writeU8(T.I16)
				self:writeI16(v)
			elseif v >= 0 and v <= 65535 then
				self:writeU8(T.U16)
				self:writeU16(v)
			else
				self:writeU8(T.I32)
				self:writeI32(v)
			end
		else
			local f32 = buffer.create(4)
			buffer.writef32(f32, 0, v)

			if math.abs(buffer.readf32(f32, 0) - v) < 1e-6 then
				self:writeU8(T.F32)
				self:writeF32(v)
			else
				self:writeU8(T.F64)
				self:writeF64(v)
			end
		end
	elseif t == "string" then
		self:writeU8(T.STRING)
		self:writeString(v)
	elseif t == "Vector3" then
		self:writeU8(T.VECTOR3)
		self:writeVector3(v)
	elseif t == "Vector2" then
		self:writeU8(T.VECTOR2)
		self:writeVector2(v)
	elseif t == "CFrame" then
		self:writeU8(T.CFRAME_FULL)
		self:writeCFrame(v)
	elseif t == "Color3" then
		local isRGB = (v.R * 255) == math.floor(v.R * 255)

		if isRGB then
			self:writeU8(T.COLOR3_RGB)
			self:writeColor3(v, true)
		else
			self:writeU8(T.COLOR3_F)
			self:writeColor3(v, false)
		end
	elseif t == "BrickColor" then
		self:writeU8(T.BRICKCOLOR)
		self:writeU16(v.Number)
	elseif t == "UDim" then
		self:writeU8(T.UDIM)
		self:writeUDim(v)
	elseif t == "UDim2" then
		self:writeU8(T.UDIM2)
		self:writeUDim2(v)
	elseif t == "Rect" then
		self:writeU8(T.RECT)
		self:writeRect(v)
	elseif t == "NumberRange" then
		self:writeU8(T.NUMRANGE)
		self:writeNumRange(v)
	elseif t == "NumberSequence" then
		self:writeU8(T.NUMSEQ)

		local kps = v.Keypoints
		self:writeU8(#kps)

		for _, kp in kps do
			self:writeF32(kp.Time)
			self:writeF32(kp.Value)
			self:writeF32(kp.Envelope)
		end
	elseif t == "ColorSequence" then
		self:writeU8(T.COLORSEQ)

		local kps = v.Keypoints
		self:writeU8(#kps)

		for _, kp in kps do
			self:writeF32(kp.Time)
			self:writeColor3(kp.Value, false)
		end
	elseif t == "Instance" then
		self:writeU8(T.INSTANCE)
		self:writeInstance(v)
	elseif t == "EnumItem" then
		self:writeU8(T.ENUM)
		self:writeEnum(v)
	elseif t == "Vector4" then
		self:writeU8(T.VECTOR4)
		self:writeF32(v.X)
		self:writeF32(v.Y)
		self:writeF32(v.Z)
		self:writeF32(v.W)
	elseif t == "Region3" then
		self:writeU8(T.REGION3)
		self:writeVector3(v.CFrame.Position)
		self:writeVector3(v.Size)
	elseif t == "Ray" then
		self:writeU8(T.RAY)
		self:writeVector3(v.Origin)
		self:writeVector3(v.Direction)
	elseif t == "table" then
		local isArray = true
		local count = 0

		for k in v do
			count += 1

			if type(k) ~= "number" or k ~= math.floor(k) then
				isArray = false
				break
			end
		end
		isArray = isArray and (count == #v)

		if isArray then
			self:writeU8(T.ARRAY)
			self:writeU32(#v)

			for _, item in v do
				self:writeValue(item)
			end
		else
			self:writeU8(T.TABLE)
			self:writeU32(count)

			for k, item in v do
				self:writeValue(k)
				self:writeValue(item)
			end
		end
	else
		self:writeU8(T.NIL)
	end
end

function writer:toResult(): encodeResult
	local out = buffer.create(self._cursor)
	buffer.copy(out, 0, self._buf, 0, self._cursor)

	return { buf = out, instances = self._instances }
end

--// Reader Decleration
local reader = {}
reader.__index = reader

--// Reader Functions
function reader.new(buf: buffer, instances: { Instance }): readerType
	return setmetatable({
		_buf = buf,
		_cursor = 0,
		_size = buffer.len(buf),
		_instances = instances or {},
	}, reader) :: any
end

function reader:readU8(): number
	return (function()
		local v = buffer.readu8(self._buf, self._cursor)
		self._cursor += 1

		return v
	end)()
end

function reader:readU16(): number
	return (function()
		local v = buffer.readu16(self._buf, self._cursor)
		self._cursor += 2

		return v
	end)()
end

function reader:readU32(): number
	return (function()
		local v = buffer.readu32(self._buf, self._cursor)
		self._cursor += 4

		return v
	end)()
end

function reader:readI8(): number
	return (function()
		local v = buffer.readi8(self._buf, self._cursor)
		self._cursor += 1

		return v
	end)()
end

function reader:readI16(): number
	return (function()
		local v = buffer.readi16(self._buf, self._cursor)
		self._cursor += 2

		return v
	end)()
end

function reader:readI32(): number
	return (function()
		local v = buffer.readi32(self._buf, self._cursor)
		self._cursor += 4

		return v
	end)()
end

function reader:readF32(): number
	return (function()
		local v = buffer.readf32(self._buf, self._cursor)
		self._cursor += 4

		return v
	end)()
end

function reader:readF64(): number
	return (function()
		local v = buffer.readf64(self._buf, self._cursor)
		self._cursor += 8

		return v
	end)()
end

function reader:readString(): string
	local len = self:readU32()
	local s = buffer.readstring(self._buf, self._cursor, len)
	self._cursor += len

	return s
end

function reader:readBool(): boolean
	return self:readU8() == 1
end

function reader:isEOF(): boolean
	return self._cursor >= self._size
end

function reader:readValue(): any
	if self:isEOF() then
		return nil
	end

	local tag = self:readU8()

	if tag == T.NIL then
		return nil
	elseif tag == T.BOOL then
		return self:readBool()
	elseif tag == T.F64 then
		return self:readF64()
	elseif tag == T.F32 then
		return self:readF32()
	elseif tag == T.I8 then
		return self:readI8()
	elseif tag == T.U8 then
		return self:readU8()
	elseif tag == T.I16 then
		return self:readI16()
	elseif tag == T.U16 then
		return self:readU16()
	elseif tag == T.I32 then
		return self:readI32()
	elseif tag == T.U32 then
		return self:readU32()
	elseif tag == T.STRING then
		return self:readString()
	elseif tag == T.VECTOR3 then
		return Vector3.new(self:readF32(), self:readF32(), self:readF32())
	elseif tag == T.VECTOR2 then
		return Vector2.new(self:readF32(), self:readF32())
	elseif tag == T.CFRAME_FULL then
		local px, py, pz = self:readF32(), self:readF32(), self:readF32()
		local rx, ry, rz = self:readF32(), self:readF32(), self:readF32()

		return CFrame.new(px, py, pz) * CFrame.fromEulerAnglesXYZ(rx, ry, rz)
	elseif tag == T.COLOR3_F then
		return Color3.new(self:readF32(), self:readF32(), self:readF32())
	elseif tag == T.COLOR3_RGB then
		return Color3.fromRGB(self:readU8(), self:readU8(), self:readU8())
	elseif tag == T.BRICKCOLOR then
		return BrickColor.new(self:readU16())
	elseif tag == T.UDIM then
		return UDim.new(self:readF32(), self:readI32())
	elseif tag == T.UDIM2 then
		return UDim2.new(self:readF32(), self:readI32(), self:readF32(), self:readI32())
	elseif tag == T.RECT then
		return Rect.new(self:readF32(), self:readF32(), self:readF32(), self:readF32())
	elseif tag == T.NUMRANGE then
		return NumberRange.new(self:readF32(), self:readF32())
	elseif tag == T.NUMSEQ then
		local count = self:readU8()
		local kps = {} :: { NumberSequenceKeypoint }

		for _ = 1, count do
			table.insert(kps, NumberSequenceKeypoint.new(self:readF32(), self:readF32(), self:readF32()))
		end

		return NumberSequence.new(kps)
	elseif tag == T.COLORSEQ then
		local count = self:readU8()
		local kps = {} :: { ColorSequenceKeypoint }

		for _ = 1, count do
			local t2 = self:readF32()
			local c = Color3.new(self:readF32(), self:readF32(), self:readF32())

			table.insert(kps, ColorSequenceKeypoint.new(t2, c))
		end

		return ColorSequence.new(kps)
	elseif tag == T.INSTANCE then
		local idx = self:readU16()
		return self._instances[idx + 1]
	elseif tag == T.ENUM then
		local str = self:readString()
		local parts = string.split(str, ".")

		local ok, enumItem = pcall(function()
			return (Enum :: any)[parts[1]][parts[2]]
		end)

		return ok and enumItem or nil
	elseif tag == T.REGION3 then
		local pos = Vector3.new(self:readF32(), self:readF32(), self:readF32())
		local size = Vector3.new(self:readF32(), self:readF32(), self:readF32())

		return Region3.new(pos - size / 2, pos + size / 2)
	elseif tag == T.RAY then
		local origin = Vector3.new(self:readF32(), self:readF32(), self:readF32())
		local dir = Vector3.new(self:readF32(), self:readF32(), self:readF32())

		return Ray.new(origin, dir)
	elseif tag == T.ARRAY then
		local count = self:readU32()
		local arr = {}

		for i = 1, count do
			arr[i] = self:readValue()
		end

		return arr
	elseif tag == T.TABLE then
		local count = self:readU32()
		local tbl = {}

		for _ = 1, count do
			local k = self:readValue()
			local v = self:readValue()

			tbl[k] = v
		end

		return tbl
	else
		return nil
	end
end

--// Helper Functions
function encode(packetId: number, ...: any): buffer
	local w = writer.new()
	w:writeU16(packetId)

	for i = 1, select("#", ...) do
		w:writeValue(select(i, ...))
	end

	return w:toResult()
end

function decode(result: encodeResult): (number, { any })
	local r = reader.new(result.buf, result.instances)
	local id = r:readU16()

	local values = {} :: { any }
	while not r:isEOF() do
		table.insert(values, r:readValue())
	end

	return id, values
end

return {
	writer = writer,
	reader = reader,
	encode = encode,
	decode = decode,
	T = T,
}
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="15">
          <Properties>
            <string name="Name">compress</string>
            <string name="Source"><![CDATA[--[[
	******************************************************************************
	* @file		: .../src/utils/compress.lua
	* @author	: Scrpt2r
	* @date		: April 16 2026
	* @lastEdit	: April 17 2026 18:29
	* @brief	: Buffer byte size decreaser.
	* @version	: 0.1.5
	******************************************************************************
	* @attention
	*
	* Copyright © 2026 Axon Corporation.
	* All rights reserved.
	*
	* This software is licensed under terms that can be found in the LICENSE file
	* in the root directory of this software component.
	* If no LICENSE file comes with this software, it is provided AS-IS.
	*
	******************************************************************************
--]]

--// Constants
local COMPRESS_THRESHOLD = 64
local WINDOW_SIZE = 4096
local MIN_MATCH = 3
local MAX_MATCH = 18

local COMPRESSED_MAGIC = 0xC0
local RAW_MAGIC = 0x00

--// Functions
function compress(input: buffer): buffer
	local inputLen = buffer.len(input)

	if inputLen < COMPRESS_THRESHOLD then
		local out = buffer.create(inputLen + 1)

		buffer.writeu8(out, 0, RAW_MAGIC)
		buffer.copy(out, 1, input, 0, inputLen)

		return out
	end

	local outData = {} :: { number }
	local i = 0

	local flagBytePos = 0
	local flagBit = 0
	local flagByte = 0

	local function startFlagByte()
		flagBytePos = #outData + 1
		table.insert(outData, 0)

		flagBit = 0
		flagByte = 0
	end

	local function setFlag(isMatch: boolean)
		if isMatch then
			flagByte = flagByte + (1 * (2 ^ (7 - flagBit)))
		end

		flagBit += 1

		if flagBit == 8 then
			outData[flagBytePos] = math.floor(flagByte) % 256

			flagByte = 0
			flagBit = 0
			flagBytePos = 0
		end
	end

	local function flushFlag()
		if flagBytePos > 0 and flagBit > 0 then
			outData[flagBytePos] = math.floor(flagByte) % 256
		end
	end

	startFlagByte()

	while i < inputLen do
		local bestLen = 0
		local bestOffset = 0
		local windowStart = math.max(0, i - WINDOW_SIZE)

		if i >= MIN_MATCH then
			local byte0 = buffer.readu8(input, i)

			for j = windowStart, i, -1 do
				if buffer.readu8(input, j) == byte0 then
					local len = 0

					while
						len < MAX_MATCH
						and (i + len) < inputLen
						and buffer.readu8(input, j + len) == buffer.readu8(input, i + len)
					do
						len += 1
					end

					if len > bestLen then
						bestLen = len
						bestOffset = i - j
					end
				end
			end
		end

		if bestLen >= MIN_MATCH then
			setFlag(true)

			local lenCode = (bestLen - MIN_MATCH) % 16
			local offsetHigh = math.floor(bestOffset / 256) % 16
			local offsetLow = bestOffset % 256

			table.insert(outData, lenCode * 16 + offsetHigh)
			table.insert(outData, offsetLow)

			if flagBit == 0 and flagBytePos == 0 then
				startFlagByte()
			end

			i += bestLen
		else
			setFlag(false)

			table.insert(outData, buffer.readu8(input, i))

			if flagBit == 0 and flagBytePos == 0 then
				startFlagByte()
			end

			i += 1
		end
	end

	flushFlag()

	local outLen = #outData + 1
	local outBuf = buffer.create(outLen)

	buffer.writeu8(outBuf, 0, COMPRESSED_MAGIC)

	for idx, byte in outData do
		buffer.writeu8(outBuf, idx, byte % 256)
	end

	if outLen >= inputLen + 1 then
		local raw = buffer.create(inputLen + 1)

		buffer.writeu8(raw, 0, RAW_MAGIC)
		buffer.copy(raw, 1, input, 0, inputLen)

		return raw
	end

	return outBuf
end

function decompress(input: buffer): buffer
	local magic = buffer.readu8(input, 0)

	if magic == RAW_MAGIC then
		local dataLen = buffer.len(input) - 1
		local out = buffer.create(dataLen)

		buffer.copy(out, 0, input, 1, dataLen)

		return out
	end

	if magic ~= COMPRESSED_MAGIC then
		return input
	end

	local inputLen = buffer.len(input)
	local i = 1
	local out = {} :: { number }

	while i < inputLen do
		local flagByte = buffer.readu8(input, i)
		i += 1

		for bit = 7, 0, -1 do
			if i >= inputLen then
				break
			end

			local isMatch = (math.floor(flagByte / (2 ^ bit)) % 2) == 1

			if isMatch then
				if i + 1 >= inputLen then
					break
				end

				local byte1 = buffer.readu8(input, i)
				local byte2 = buffer.readu8(input, i + 1)
				i += 2

				local lenCode = math.floor(byte1 / 16)
				local offsetHigh = byte1 % 16
				local offsetLow = byte2
				local matchLen = lenCode + MIN_MATCH
				local offset = offsetHigh * 256 + offsetLow

				local startPos = #out - offset + 1
				for k = 0, matchLen - 1 do
					local srcIdx = startPos + k

					if srcIdx >= 1 and srcIdx <= #out then
						table.insert(out, out[srcIdx])
					end
				end
			else
				table.insert(out, buffer.readu8(input, i))
				i += 1
			end
		end
	end

	local outBuf = buffer.create(#out)

	for idx, byte in out do
		buffer.writeu8(outBuf, idx - 1, byte)
	end

	return outBuf
end

function ratio(original: buffer, compressed: buffer): string
	local orig = buffer.len(original)
	local comp = buffer.len(compressed)
	local pct = math.floor((1 - comp / orig) * 100)

	return string.format("%d → %d bytes (%s%d%%)", orig, comp, pct >= 0 and "-" or "+", math.abs(pct))
end

return {
	compress = compress,
	decompress = decompress,
	ratio = ratio,
	THRESHOLD = COMPRESS_THRESHOLD,
}
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="16">
          <Properties>
            <string name="Name">packet</string>
            <string name="Source"><![CDATA[--[[
	******************************************************************************
	* @file		: .../src/utils/packet.lua
	* @author	: Scrpt2r
	* @date		: April 16 2026
	* @lastEdit	: April 17 2026 18:30
	* @brief	: Packet handler for ByteFlow.
	* @version	: 0.1.5
	******************************************************************************
	* @attention
	*
	* Copyright © 2026 Axon Corporation.
	* All rights reserved.
	*
	* This software is licensed under terms that can be found in the LICENSE file
	* in the root directory of this software component.
	* If no LICENSE file comes with this software, it is provided AS-IS.
	*
	******************************************************************************
--]]

--// Libs
local types = require(script.Parent.Parent:WaitForChild("global"):WaitForChild("types"))

--// Types
export type _channel = types.channel
type channel = _channel

export type _direction = types.direction
type direction = _direction

export type _packetDef = types.packetDef
type packetDef = _packetDef

--// Variables
local _byName = {} :: { [string]: packetDef }
local _byId = {} :: { [string]: packetDef }
local _nextId = 1

--// Lib Decleration
local packet = {}

--// Lib Functions
function packet.define(name: string, opts: { channel: channel?, direction: direction? }): packetDef
	if _byName[name] then
		return _byName[name]
	end

	local def = {
		id = _nextId,
		name = name,
		channel = opts.channel or "reliable",
		direction = opts.direction or "c2s",
	} :: packetDef

	_byName[name] = def
	_byId[_nextId] = def
	_nextId += 1

	return def
end

function packet.id(name: string): number
	local def = _byName[name]
	return def.id
end

function packet.name(id: number): string
	local def = _byId[id]
	return def and def.name or ("UNKNOWN_" .. tostring(id))
end

function packet.get(name: string): packetDef
	local def = _byName[name]
	return def
end

function packet.getById(id: number): packetDef?
	return _byId[id]
end

function packet.list(): { packetDef }
	local result = {} :: { packetDef }

	for _, def in _byName do
		table.insert(result, def)
	end

	table.sort(result, function(a, b)
		return a.id < b.id
	end)

	return result
end

return packet
]]></string>
          </Properties>
        </Item>
      </Item>
    </Item>
  </Item>
</roblox>